<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    controllerName="com.trusaic.rti.home.controller.MyRequestsFCL"
    displayBlock="true">

    <Page showHeader="false">
        <content>
            <f:FlexibleColumnLayout
                id="fcl"
                layout="{/fclLayout}"
                backgroundDesign="Translucent">

                <f:beginColumnPages>
                    <mvc:XMLView viewName="com.trusaic.rti.home.view.MyRequests" id="myRequestsView"/>
                </f:beginColumnPages>

                <f:midColumnPages>
                    <mvc:XMLView viewName="com.trusaic.rti.home.view.RequestDetail" id="requestDetailView"/>
                </f:midColumnPages>

            </f:FlexibleColumnLayout>
        </content>
    </Page>

</mvc:View>