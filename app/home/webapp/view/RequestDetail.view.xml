<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    controllerName="com.trusaic.rti.home.controller.RequestDetail"
    displayBlock="true">

    <Page title="Request Detail"
          showNavButton="true"
          navButtonPress=".onNavBack">
        <content>
            <layout:VerticalLayout class="sapUiMediumMargin" width="auto">

                <!-- Request Info Section -->
                <form:SimpleForm
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="3" labelSpanM="3"
                    emptySpanL="4" emptySpanM="4"
                    columnsL="1" columnsM="1"
                    class="sapUiMediumMarginBottom">

                    <form:toolbar>
                        <Toolbar>
                            <Title text="Request Information"/>
                        </Toolbar>
                    </form:toolbar>

                    <Label text="Request ID"/>
                    <Text text="{/request/ID}"/>

                    <Label text="Request Type"/>
                    <Text text="{/request/requestType}"/>

                    <Label text="Comparison Group"/>
                    <Text text="{/request/comparisonGroup}"/>

                    <Label text="Justification"/>
                    <Text text="{= ${/request/justification} || '—'}"/>

                    <Label text="Date Submitted"/>
                    <Text text="{parts: ['/request/submittedAt'], formatter: '.formatDate'}"/>

                    <Label text="Status"/>
                    <ObjectStatus
                        text="{= ${/request/status} === 'UnderReview' ? 'Under Review' : ${/request/status}}"
                        state="{= ${/request/status} === 'Submitted' ? 'Information' :
                                 ${/request/status} === 'UnderReview' ? 'Warning' :
                                 ${/request/status} === 'Approved' ? 'Success' :
                                 ${/request/status} === 'Completed' ? 'Success' :
                                 ${/request/status} === 'Denied' ? 'Error' : 'None'}"/>

                </form:SimpleForm>

                <!-- Status Timeline -->
                <Panel headerText="Status Timeline" class="sapUiMediumMarginBottom">
                    <content>
                        <List items="{/statusHistory}">
                            <FeedListItem
                                sender="{changedBy}"
                                timestamp="{parts: ['changedAt'], formatter: '.formatDate'}"
                                text="{= ${status} === 'UnderReview' ? 'Under Review' : ${status}}{= ${note} ? ' — ' + ${note} : ''}"
                                icon="{= ${status} === 'Submitted' ? 'sap-icon://paper-plane' :
                                        ${status} === 'UnderReview' ? 'sap-icon://pending' :
                                        ${status} === 'Approved' ? 'sap-icon://accept' :
                                        ${status} === 'Completed' ? 'sap-icon://complete' :
                                        ${status} === 'Denied' ? 'sap-icon://decline' : ''}"/>
                        </List>
                    </content>
                </Panel>

                <!-- Denial Reason (shown only when denied) -->
                <Panel headerText="Denial Reason"
                       class="sapUiMediumMarginBottom"
                       visible="{= ${/request/status} === 'Denied'}">
                    <content>
                        <MessageStrip
                            text="{/request/denialReason}"
                            type="Error"
                            showIcon="true"
                            class="sapUiSmallMargin"/>
                    </content>
                </Panel>

                <!-- Processing Message (shown for Submitted / UnderReview) -->
                <MessageStrip
                    text="Your request is being processed."
                    type="Information"
                    showIcon="true"
                    visible="{= ${/request/status} === 'Submitted' || ${/request/status} === 'UnderReview'}"
                    class="sapUiMediumMarginBottom"/>

                <!-- Approved Awaiting Report (shown for Approved without report) -->
                <MessageStrip
                    text="Approved — response being generated by PayParity."
                    type="Success"
                    showIcon="true"
                    visible="{= ${/request/status} === 'Approved' &amp;&amp; !${/report}}"
                    class="sapUiMediumMarginBottom"/>

                <!-- RTI Report (shown when Completed) -->
                <Panel headerText="RTI Report"
                       class="sapUiMediumMarginBottom"
                       visible="{= ${/request/status} === 'Completed' &amp;&amp; !!${/report}}">
                    <content>
                        <layout:VerticalLayout class="sapUiSmallMargin" width="100%">

                            <!-- Employee Details -->
                            <Panel headerText="Employee Details"
                                   visible="{= !!${/reportParsed/data/employee}}"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="employeeDetailsBox" class="sapUiSmallMargin"/>
                                </content>
                            </Panel>

                            <!-- Employee Pay -->
                            <Panel headerText="Employee Pay"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="employeePayBox" class="sapUiSmallMargin"/>
                                </content>
                            </Panel>

                            <!-- Comparison Group Pay -->
                            <Panel headerText="Comparison Group"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="compGroupPayBox" class="sapUiSmallMargin"/>
                                </content>
                            </Panel>

                            <!-- Comparison Group Size -->
                            <Text text="Comparison Group Size: {/reportParsed/data/comparisonGroupSize} employees"
                                  visible="{= !!${/reportParsed/data/comparisonGroupSize}}"
                                  class="sapUiSmallMarginBottom"/>

                            <!-- Narrative -->
                            <Panel headerText="Narrative"
                                   visible="{= !!${/report/narrative}}"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <Text text="{/report/narrative}" class="sapUiSmallMargin"/>
                                </content>
                            </Panel>

                            <!-- Download Link -->
                            <Link text="Download PDF Report"
                                  href="{/report/reportFileUrl}"
                                  target="_blank"
                                  visible="{= !!${/report/reportFileUrl}}"
                                  class="sapUiSmallMarginTop"/>

                        </layout:VerticalLayout>
                    </content>
                </Panel>

            </layout:VerticalLayout>
        </content>
    </Page>

</mvc:View>