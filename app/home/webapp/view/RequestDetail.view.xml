<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    controllerName="com.trusaic.rti.home.controller.RequestDetail"
    displayBlock="true">

    <Page title="Request Detail"
          showNavButton="false">
        <headerContent>
            <Button icon="sap-icon://decline"
                    type="Transparent"
                    press=".onCloseDetail"
                    tooltip="Close detail"/>
        </headerContent>
        <content>
            <layout:VerticalLayout class="sapUiSmallMargin" width="auto">

                <form:SimpleForm
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="4" labelSpanM="4"
                    emptySpanL="1" emptySpanM="1"
                    columnsL="1" columnsM="1"
                    class="sapUiSmallMarginBottom">

                    <form:toolbar>
                        <Toolbar>
                            <Title text="Request Information"/>
                        </Toolbar>
                    </form:toolbar>

                    <Label text="Request ID"/>
                    <Text text="{detail>/request/ID}"/>
                    <Label text="Request Type"/>
                    <Text text="{detail>/request/requestType}"/>
                    <Label text="Comparison Group"/>
                    <Text text="{detail>/request/comparisonGroup}"/>
                    <Label text="Justification"/>
                    <Text text="{= ${detail>/request/justification} || '—'}"/>
                    <Label text="Date Submitted"/>
                    <Text text="{parts: ['detail>/request/submittedAt'], formatter: '.formatDate'}"/>
                    <Label text="Status"/>
                    <ObjectStatus
                        text="{= ${detail>/request/status} === 'UnderReview' ? 'Under Review' : ${detail>/request/status}}"
                        state="{= ${detail>/request/status} === 'Submitted' ? 'Information' :
                                 ${detail>/request/status} === 'UnderReview' ? 'Warning' :
                                 ${detail>/request/status} === 'Approved' ? 'Success' :
                                 ${detail>/request/status} === 'Completed' ? 'Success' :
                                 ${detail>/request/status} === 'Denied' ? 'Error' : 'None'}"/>
                </form:SimpleForm>

                <Panel headerText="Status Timeline" class="sapUiSmallMarginBottom">
                    <content>
                        <List items="{detail>/statusHistory}">
                            <FeedListItem
                                sender="{detail>changedBy}"
                                timestamp="{parts: ['detail>changedAt'], formatter: '.formatDate'}"
                                text="{= ${detail>status} === 'UnderReview' ? 'Under Review' : ${detail>status}}{= ${detail>note} ? ' — ' + ${detail>note} : ''}"
                                icon="{= ${detail>status} === 'Submitted' ? 'sap-icon://paper-plane' :
                                        ${detail>status} === 'UnderReview' ? 'sap-icon://pending' :
                                        ${detail>status} === 'Approved' ? 'sap-icon://accept' :
                                        ${detail>status} === 'Completed' ? 'sap-icon://complete' :
                                        ${detail>status} === 'Denied' ? 'sap-icon://decline' : ''}"/>
                        </List>
                    </content>
                </Panel>

                <Panel headerText="Denial Reason"
                       class="sapUiSmallMarginBottom"
                       visible="{= ${detail>/request/status} === 'Denied'}">
                    <content>
                        <MessageStrip
                            text="{detail>/request/denialReason}"
                            type="Error"
                            showIcon="true"
                            class="sapUiSmallMargin"/>
                    </content>
                </Panel>

                <MessageStrip
                    text="Your request is being processed."
                    type="Information"
                    showIcon="true"
                    visible="{= ${detail>/request/status} === 'Submitted' || ${detail>/request/status} === 'UnderReview'}"
                    class="sapUiSmallMarginBottom"/>

                <MessageStrip
                    text="Approved — response being generated by PayParity."
                    type="Success"
                    showIcon="true"
                    visible="{= ${detail>/request/status} === 'Approved' &amp;&amp; !${detail>/report}}"
                    class="sapUiSmallMarginBottom"/>

                <Panel headerText="RTI Report"
                       class="sapUiSmallMarginBottom"
                       visible="{= ${detail>/request/status} === 'Completed' &amp;&amp; !!${detail>/report}}">
                    <content>
                        <layout:VerticalLayout class="sapUiSmallMargin" width="100%">
                            <Panel headerText="Employee Details"
                                   visible="{= !!${detail>/reportParsed/data/employee}}"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="employeeDetailsBox" class="sapUiSmallMargin"
                                          renderType="Bare" wrap="Wrap"/>
                                </content>
                            </Panel>
                            <Panel headerText="Employee Pay"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="employeePayBox" class="sapUiSmallMargin"
                                          renderType="Bare" wrap="Wrap"/>
                                </content>
                            </Panel>
                            <Panel headerText="Comparison Group"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="compGroupPayBox" class="sapUiSmallMargin"
                                          renderType="Bare" wrap="Wrap"/>
                                </content>
                            </Panel>
                            <Text text="Comparison Group Size: {detail>/reportParsed/data/comparisonGroupSize} employees"
                                  visible="{= !!${detail>/reportParsed/data/comparisonGroupSize}}"
                                  class="sapUiSmallMarginBottom"/>
                            <Panel headerText="Narrative"
                                   visible="{= !!${detail>/report/narrative}}"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <Text text="{detail>/report/narrative}" class="sapUiSmallMargin"
                                          wrapping="true"/>
                                </content>
                            </Panel>
                            <Link text="Download PDF Report"
                                  href="{detail>/report/reportFileUrl}"
                                  target="_blank"
                                  visible="{= !!${detail>/report/reportFileUrl}}"
                                  class="sapUiSmallMarginTop"/>
                        </layout:VerticalLayout>
                    </content>
                </Panel>

            </layout:VerticalLayout>
        </content>
    </Page>

</mvc:View>