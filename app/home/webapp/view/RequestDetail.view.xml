<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    controllerName="com.trusaic.rti.home.controller.RequestDetail"
    displayBlock="true">

    <Page title="Request Detail"
          showNavButton="false">
        <headerContent>
            <Button icon="sap-icon://decline"
                    type="Transparent"
                    press=".onCloseDetail"
                    tooltip="Close detail"/>
        </headerContent>
        <content>
            <layout:VerticalLayout class="sapUiSmallMargin" width="auto">

                <form:SimpleForm
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="4" labelSpanM="4"
                    emptySpanL="1" emptySpanM="1"
                    columnsL="1" columnsM="1"
                    class="sapUiSmallMarginBottom">

                    <form:toolbar>
                        <Toolbar>
                            <Title text="Request Information"/>
                        </Toolbar>
                    </form:toolbar>

                    <Label text="Request ID"/>
                    <Text text="{detail>/request/ID}"/>
                    <Label text="Request Type"/>
                    <Text text="{detail>/request/requestType}"/>
                    <Label text="Comparison Group"/>
                    <Text text="{detail>/request/comparisonGroup}"/>
                    <Label text="Justification"/>
                    <Text text="{= ${detail>/request/justification} || '—'}"/>
                    <Label text="Date Submitted"/>
                    <Text text="{parts: ['detail>/request/submittedAt'], formatter: '.formatDate'}"/>
                    <Label text="Status"/>
                    <ObjectStatus
                        text="{= ${detail>/request/status} === 'UnderReview' ? 'Under Review' : ${detail>/request/status}}"
                        state="{= ${detail>/request/status} === 'Submitted' ? 'Information' :
                                 ${detail>/request/status} === 'UnderReview' ? 'Warning' :
                                 ${detail>/request/status} === 'Approved' ? 'Success' :
                                 ${detail>/request/status} === 'Completed' ? 'Success' :
                                 ${detail>/request/status} === 'Denied' ? 'Error' : 'None'}"/>
                </form:SimpleForm>

                <Panel headerText="Status Timeline" class="sapUiSmallMarginBottom">
                    <content>
                        <List items="{detail>/statusHistory}">
                            <FeedListItem
                                sender="{detail>changedBy}"
                                timestamp="{parts: ['detail>changedAt'], formatter: '.formatDate'}"
                                text="{= ${detail>status} === 'UnderReview' ? 'Under Review' : ${detail>status}}{= ${detail>note} ? ' — ' + ${detail>note} : ''}"
                                icon="{= ${detail>status} === 'Submitted' ? 'sap-icon://paper-plane' :
                                        ${detail>status} === 'UnderReview' ? 'sap-icon://pending' :
                                        ${detail>status} === 'Approved' ? 'sap-icon://accept' :
                                        ${detail>status} === 'Completed' ? 'sap-icon://complete' :
                                        ${detail>status} === 'Denied' ? 'sap-icon://decline' : ''}"/>
                        </List>
                    </content>
                </Panel>

                <Panel headerText="Denial Reason"
                       class="sapUiSmallMarginBottom"
                       visible="{= ${detail>/request/status} === 'Denied'}">
                    <content>
                        <MessageStrip
                            text="{detail>/request/denialReason}"
                            type="Error"
                            showIcon="true"
                            class="sapUiSmallMargin"/>
                    </content>
                </Panel>

                <MessageStrip
                    text="Your request is being processed."
                    type="Information"
                    showIcon="true"
                    visible="{= ${detail>/request/status} === 'Submitted' || ${detail>/request/status} === 'UnderReview'}"
                    class="sapUiSmallMarginBottom"/>

                <MessageStrip
                    text="Approved — response being generated by PayParity."
                    type="Success"
                    showIcon="true"
                    visible="{= ${detail>/request/status} === 'Approved' &amp;&amp; !${detail>/report}}"
                    class="sapUiSmallMarginBottom"/>

                <Panel headerText="RTI Report"
                       class="sapUiSmallMarginBottom"
                       visible="{= ${detail>/request/status} === 'Completed' &amp;&amp; !!${detail>/report}}">
                    <content>
                        <layout:VerticalLayout class="sapUiSmallMargin" width="100%">
                            <Panel headerText="Employee Details"
                                   visible="{= !!${detail>/reportParsed/data/employee}}"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="employeeDetailsBox" class="sapUiSmallMargin"
                                          renderType="Bare" wrap="Wrap"/>
                                </content>
                            </Panel>
                            <Panel headerText="Employee Pay"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="employeePayBox" class="sapUiSmallMargin"
                                          renderType="Bare" wrap="Wrap"/>
                                </content>
                            </Panel>
                            <Panel headerText="Comparison Group"
                                   class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox id="compGroupPayBox" class="sapUiSmallMargin"
                                          renderType="Bare" wrap="Wrap"/>
                                </content>
                            </Panel>
                            <Text text="Comparison Group Size: {detail>/reportParsed/data/comparisonGroupSize} employees"
                                  visible="{= !!${detail>/reportParsed/data/comparisonGroupSize}}"
                                  class="sapUiSmallMarginBottom"/>
                            <Panel headerText="Narrative"
                                visible="{= !!${detail>/report/narrative}}"
                                class="sapUiSmallMarginBottom">
                                <content>
                                    <VBox id="narrativeBox" class="sapUiSmallMargin" width="100%"/>
                                </content>
                            </Panel>
                            <Link text="Download PDF Report"
                                  href="{detail>/report/reportFileUrl}"
                                  target="_blank"
                                  visible="{= !!${detail>/report/reportFileUrl}}"
                                  class="sapUiSmallMarginTop"/>
                        </layout:VerticalLayout>
                    </content>
                </Panel>

                <!-- ============================================================ -->
                <!-- Discussion Panel — visible on completed reports               -->
                <!-- ============================================================ -->
                <Panel headerText="Discussion"
                       class="sapUiSmallMarginBottom"
                       visible="{= ${detail>/request/status} === 'Completed' &amp;&amp; !!${detail>/report}}">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Discussion"/>
                            <ToolbarSpacer/>
                            <ObjectStatus
                                text="{detail>/commentCount} {= ${detail>/commentCount} === 1 ? 'comment' : 'comments'}"
                                state="Information"/>
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <layout:VerticalLayout class="sapUiSmallMargin" width="100%">

                            <!-- Empty state -->
                            <VBox alignItems="Center"
                                  visible="{= ${detail>/commentCount} === 0}"
                                  class="sapUiMediumMargin">
                                <core:Icon src="sap-icon://discussion"
                                           size="2.5rem"
                                           color="#999"
                                           class="sapUiSmallMarginBottom"/>
                                <Text text="No comments yet. Start the conversation about this report."
                                      textAlign="Center"/>
                            </VBox>

                            <!-- Conversation thread -->
                            <List id="commentsList"
                                  items="{detail>/comments}"
                                  showSeparators="None"
                                  visible="{= ${detail>/commentCount} > 0}"
                                  backgroundDesign="Transparent">
                                <CustomListItem class="sapUiTinyMarginBottom">
                                    <HBox justifyContent="{= ${detail>authorRole} === 'Requestor' ? 'End' : 'Start'}"
                                          width="100%"
                                          class="sapUiTinyMarginBottom sapUiTinyMarginTop">
                                        <VBox width="80%"
                                              class="{= ${detail>authorRole} === 'Requestor' ? 'rtiCommentRequestor' : 'rtiCommentResponder'}">
                                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                                <core:Icon src="{= ${detail>authorRole} === 'Requestor' ? 'sap-icon://employee' : 'sap-icon://customer'}"
                                                           size="1rem"
                                                           class="sapUiTinyMarginEnd"/>
                                                <Text text="{detail>authorName}"
                                                      class="sapUiTinyMarginEnd"/>
                                                <Text text="·" class="sapUiTinyMarginEnd"/>
                                                <Text text="{parts: ['detail>postedAt'], formatter: '.formatDateTime'}"/>
                                            </HBox>
                                            <Text text="{detail>message}" wrapping="true"/>
                                        </VBox>
                                    </HBox>
                                </CustomListItem>
                            </List>

                            <!-- Compose -->
                            <Panel class="sapUiSmallMarginTop" backgroundDesign="Transparent">
                                <content>
                                    <VBox class="sapUiSmallMargin">
                                        <Label text="Add a comment"
                                               labelFor="newCommentInput"
                                               class="sapUiTinyMarginBottom"/>
                                        <TextArea id="newCommentInput"
                                                  value="{detail>/newCommentText}"
                                                  placeholder="Type your comment here. The HR Admin team will see this."
                                                  rows="3"
                                                  growing="true"
                                                  growingMaxLines="8"
                                                  width="100%"
                                                  maxLength="5000"/>
                                        <HBox justifyContent="End" class="sapUiSmallMarginTop">
                                            <Button text="Post Comment"
                                                    type="Emphasized"
                                                    icon="sap-icon://paper-plane"
                                                    press=".onPostComment"
                                                    enabled="{= !!${detail>/newCommentText} &amp;&amp; ${detail>/newCommentText}.length > 0}"/>
                                        </HBox>
                                    </VBox>
                                </content>
                            </Panel>

                        </layout:VerticalLayout>
                    </content>
                </Panel>

            </layout:VerticalLayout>
        </content>
    </Page>

</mvc:View>