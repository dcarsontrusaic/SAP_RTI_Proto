<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    controllerName="com.trusaic.rti.home.controller.AdminSettings"
    displayBlock="true">

    <Page title="Admin Settings"
          showNavButton="true"
          navButtonPress=".onNavBack">
        <content>
            <IconTabBar id="adminTabs" selectedKey="projectMapping" class="sapUiNoContentPadding">
                <items>

                    <!-- Tab 1: Project Mapping -->
                    <IconTabFilter key="projectMapping" text="Project Mapping" icon="sap-icon://group">
                        <layout:VerticalLayout class="sapUiMediumMargin" width="auto">
                            <Title text="Map Employee Groups to Trusaic Projects" level="H3" class="sapUiSmallMarginBottom"/>
                            <Text text="For each PayParity project, assign which employee groups can submit requests (requestors) and which groups can approve them (approvers)."
                                  class="sapUiSmallMarginBottom" wrapping="true"/>

                            <!-- Add Project Mapping -->
                            <Panel headerText="Add Project Mapping" class="sapUiSmallMarginBottom">
                                <content>
                                    <layout:VerticalLayout class="sapUiSmallMargin" width="100%">

                                        <!-- Project selection -->
                                        <HBox alignItems="End" wrap="Wrap" class="sapUiSmallMarginBottom">
                                            <VBox class="sapUiSmallMarginEnd">
                                                <Label text="Trusaic Project" required="true"/>
                                                <ComboBox id="pmProject"
                                                          value="{admin>/pm/newProject}"
                                                          placeholder="Type or select a project..."
                                                          width="300px"
                                                          items="{admin>/suggestions/projects}">
                                                    <core:ListItem key="{admin>key}" text="{admin>text}"/>
                                                </ComboBox>
                                            </VBox>
                                        </HBox>

                                        <!-- Requestor entry -->
                                        <HBox alignItems="End" wrap="Wrap" class="sapUiSmallMarginBottom">
                                            <VBox class="sapUiSmallMarginEnd">
                                                <Label text="Group Type"/>
                                                <Select id="pmRequestorType"
                                                        selectedKey="{admin>/pm/newRequestorType}"
                                                        change=".onRequestorTypeChange"
                                                        width="180px">
                                                    <items>
                                                        <core:Item key="SFDynamic" text="SF Dynamic Group"/>
                                                        <core:Item key="SFStatic" text="SF Static Group"/>
                                                        <core:Item key="IASGroup" text="IAS User Group"/>
                                                        <core:Item key="RoleCollection" text="BTP Role Collection"/>
                                                        <core:Item key="Individual" text="Individual User"/>
                                                    </items>
                                                </Select>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd">
                                                <Label text="Requestor"/>
                                                <ComboBox id="pmRequestorValue"
                                                          value="{admin>/pm/newRequestorValue}"
                                                          placeholder="Type or select..."
                                                          width="260px"
                                                          items="{admin>/pm/filteredRequestorSuggestions}">
                                                    <core:ListItem key="{admin>key}" text="{admin>text}"/>
                                                </ComboBox>
                                            </VBox>
                                            <Button text="Add Requestor"
                                                    icon="sap-icon://add"
                                                    type="Default"
                                                    press=".onPmAddRequestor"
                                                    class="sapUiSmallMarginBottom"/>
                                        </HBox>

                                        <!-- Staged requestors -->
                                        <VBox visible="{= ${admin>/pm/pendingRequestors}.length > 0}"
                                              class="sapUiSmallMarginBottom">
                                            <Label text="Requestors added:" class="sapUiTinyMarginBottom"/>
                                            <HBox wrap="Wrap" alignItems="Center"
                                                  items="{admin>/pm/pendingRequestors}">
                                                <Token text="{admin>display}"
                                                       editable="true"
                                                       delete=".onPmRemovePendingRequestor"
                                                       class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                                            </HBox>
                                        </VBox>

                                        <!-- Approver entry -->
                                        <HBox alignItems="End" wrap="Wrap" class="sapUiSmallMarginBottom">
                                            <VBox class="sapUiSmallMarginEnd">
                                                <Label text="Group Type"/>
                                                <Select id="pmApproverType"
                                                        selectedKey="{admin>/pm/newApproverType}"
                                                        change=".onApproverTypeChange"
                                                        width="180px">
                                                    <items>
                                                        <core:Item key="SFDynamic" text="SF Dynamic Group"/>
                                                        <core:Item key="SFStatic" text="SF Static Group"/>
                                                        <core:Item key="IASGroup" text="IAS User Group"/>
                                                        <core:Item key="RoleCollection" text="BTP Role Collection"/>
                                                        <core:Item key="Individual" text="Individual User"/>
                                                    </items>
                                                </Select>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd">
                                                <Label text="Approver"/>
                                                <ComboBox id="pmApproverValue"
                                                          value="{admin>/pm/newApproverValue}"
                                                          placeholder="Type or select..."
                                                          width="260px"
                                                          items="{admin>/pm/filteredApproverSuggestions}">
                                                    <core:ListItem key="{admin>key}" text="{admin>text}"/>
                                                </ComboBox>
                                            </VBox>
                                            <Button text="Add Approver"
                                                    icon="sap-icon://add"
                                                    type="Default"
                                                    press=".onPmAddApprover"
                                                    class="sapUiSmallMarginBottom"/>
                                        </HBox>

                                        <!-- Staged approvers -->
                                        <VBox visible="{= ${admin>/pm/pendingApprovers}.length > 0}"
                                              class="sapUiSmallMarginBottom">
                                            <Label text="Approvers added:" class="sapUiTinyMarginBottom"/>
                                            <HBox wrap="Wrap" alignItems="Center"
                                                  items="{admin>/pm/pendingApprovers}">
                                                <Token text="{admin>display}"
                                                       editable="true"
                                                       delete=".onPmRemovePendingApprover"
                                                       class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                                            </HBox>
                                        </VBox>

                                        <Button text="Save Project Mapping"
                                                type="Emphasized"
                                                icon="sap-icon://save"
                                                press=".onPmAdd"
                                                class="sapUiSmallMarginTop"/>
                                    </layout:VerticalLayout>
                                </content>
                            </Panel>

                            <!-- Current project mappings table -->
                            <Table items="{admin>/pm/mappings}" mode="None">
                                <headerToolbar>
                                    <Toolbar>
                                        <Title text="Current Project Mappings ({admin>/pm/count})"/>
                                    </Toolbar>
                                </headerToolbar>
                                <columns>
                                    <Column width="14em"><Text text="Trusaic Project"/></Column>
                                    <Column><Text text="Requestors"/></Column>
                                    <Column><Text text="Approvers"/></Column>
                                    <Column width="7em"><Text text="Actions"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{admin>project}"/>
                                            <Text text="{admin>requestorsDisplay}" wrapping="true"/>
                                            <Text text="{admin>approversDisplay}" wrapping="true"/>
                                            <HBox>
                                                <Button icon="sap-icon://edit"
                                                        type="Transparent"
                                                        press=".onPmEdit"
                                                        tooltip="Edit mapping"/>
                                                <Button icon="sap-icon://delete"
                                                        type="Transparent"
                                                        press=".onPmDelete"
                                                        tooltip="Delete mapping"/>
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </layout:VerticalLayout>
                    </IconTabFilter>

                    <!-- Tab 2: Admin Access -->
                    <IconTabFilter key="adminAccess" text="Admin Access" icon="sap-icon://shield">
                        <layout:VerticalLayout class="sapUiMediumMargin" width="auto">
                            <Title text="Manage RTI App Administrators" level="H3" class="sapUiSmallMarginBottom"/>
                            <Text text="Administrators have full access to the RTI app, including this Admin Settings screen. Add or remove admin users below."
                                  class="sapUiSmallMarginBottom" wrapping="true"/>

                            <!-- Add Admin -->
                            <Panel headerText="Add Administrator" class="sapUiSmallMarginBottom">
                                <content>
                                    <HBox class="sapUiSmallMargin" alignItems="End" wrap="Wrap">
                                        <VBox class="sapUiSmallMarginEnd">
                                            <Label text="User" required="true"/>
                                            <ComboBox id="adminNewUser"
                                                      value="{admin>/admins/newUser}"
                                                      placeholder="Type or select a user..."
                                                      width="320px"
                                                      items="{admin>/suggestions/individuals}">
                                                <core:ListItem key="{admin>key}" text="{admin>text}"/>
                                            </ComboBox>
                                        </VBox>
                                        <Button text="Add Admin"
                                                type="Emphasized"
                                                icon="sap-icon://add"
                                                press=".onAdminAdd"
                                                class="sapUiSmallMarginBottom"/>
                                    </HBox>
                                </content>
                            </Panel>

                            <!-- Current admins table -->
                            <Table items="{admin>/admins/list}" mode="None">
                                <headerToolbar>
                                    <Toolbar>
                                        <Title text="Current Administrators ({admin>/admins/count})"/>
                                    </Toolbar>
                                </headerToolbar>
                                <columns>
                                    <Column width="10em"><Text text="User ID"/></Column>
                                    <Column><Text text="Name"/></Column>
                                    <Column width="5em"><Text text="Actions"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{admin>userId}"/>
                                            <Text text="{admin>name}"/>
                                            <Button icon="sap-icon://delete"
                                                    type="Transparent"
                                                    press=".onAdminRemove"
                                                    tooltip="Remove admin"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </layout:VerticalLayout>
                    </IconTabFilter>

                </items>
            </IconTabBar>

            <!-- ============================================================ -->
            <!-- Edit Project Mapping Dialog                                   -->
            <!-- ============================================================ -->
            <Dialog id="pmEditDialog"
                    title="Edit Project Mapping"
                    contentWidth="640px"
                    contentHeight="auto"
                    resizable="false"
                    draggable="true">
                <content>
                    <layout:VerticalLayout class="sapUiContentPadding" width="100%">

                        <!-- Project name (read-only header) -->
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Label text="Trusaic Project:" class="sapUiSmallMarginEnd"/>
                            <Title text="{admin>/pmEdit/project}" level="H4"/>
                        </HBox>

                        <!-- ═══ Requestors section ═══ -->
                        <Panel headerText="Requestors" class="sapUiSmallMarginBottom">
                            <content>
                                <layout:VerticalLayout class="sapUiSmallMargin" width="100%">

                                    <!-- Existing requestors as removable tokens -->
                                    <HBox visible="{= ${admin>/pmEdit/requestors}.length > 0}"
                                          wrap="Wrap" alignItems="Center"
                                          class="sapUiSmallMarginBottom"
                                          items="{admin>/pmEdit/requestors}">
                                        <Token text="{admin>display}"
                                               editable="true"
                                               delete=".onPmEditRemoveRequestor"
                                               class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                                    </HBox>

                                    <Text text="No requestors assigned."
                                          visible="{= ${admin>/pmEdit/requestors}.length === 0}"
                                          class="sapUiSmallMarginBottom"/>

                                    <!-- Add new requestor -->
                                    <HBox alignItems="End" wrap="Wrap">
                                        <VBox class="sapUiSmallMarginEnd">
                                            <Label text="Group Type"/>
                                            <Select selectedKey="{admin>/pmEdit/newRequestorType}"
                                                    change=".onPmEditRequestorTypeChange"
                                                    width="180px">
                                                <items>
                                                    <core:Item key="SFDynamic" text="SF Dynamic Group"/>
                                                    <core:Item key="SFStatic" text="SF Static Group"/>
                                                    <core:Item key="IASGroup" text="IAS User Group"/>
                                                    <core:Item key="RoleCollection" text="BTP Role Collection"/>
                                                    <core:Item key="Individual" text="Individual User"/>
                                                </items>
                                            </Select>
                                        </VBox>
                                        <VBox class="sapUiSmallMarginEnd">
                                            <Label text="Requestor"/>
                                            <ComboBox value="{admin>/pmEdit/newRequestorValue}"
                                                      placeholder="Type or select..."
                                                      width="240px"
                                                      items="{admin>/pmEdit/filteredRequestorSuggestions}">
                                                <core:ListItem key="{admin>key}" text="{admin>text}"/>
                                            </ComboBox>
                                        </VBox>
                                        <Button text="Add"
                                                icon="sap-icon://add"
                                                press=".onPmEditAddRequestor"
                                                class="sapUiSmallMarginBottom"/>
                                    </HBox>
                                </layout:VerticalLayout>
                            </content>
                        </Panel>

                        <!-- ═══ Approvers section ═══ -->
                        <Panel headerText="Approvers" class="sapUiSmallMarginBottom">
                            <content>
                                <layout:VerticalLayout class="sapUiSmallMargin" width="100%">

                                    <!-- Existing approvers as removable tokens -->
                                    <HBox visible="{= ${admin>/pmEdit/approvers}.length > 0}"
                                          wrap="Wrap" alignItems="Center"
                                          class="sapUiSmallMarginBottom"
                                          items="{admin>/pmEdit/approvers}">
                                        <Token text="{admin>display}"
                                               editable="true"
                                               delete=".onPmEditRemoveApprover"
                                               class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                                    </HBox>

                                    <Text text="No approvers assigned."
                                          visible="{= ${admin>/pmEdit/approvers}.length === 0}"
                                          class="sapUiSmallMarginBottom"/>

                                    <!-- Add new approver -->
                                    <HBox alignItems="End" wrap="Wrap">
                                        <VBox class="sapUiSmallMarginEnd">
                                            <Label text="Group Type"/>
                                            <Select selectedKey="{admin>/pmEdit/newApproverType}"
                                                    change=".onPmEditApproverTypeChange"
                                                    width="180px">
                                                <items>
                                                    <core:Item key="SFDynamic" text="SF Dynamic Group"/>
                                                    <core:Item key="SFStatic" text="SF Static Group"/>
                                                    <core:Item key="IASGroup" text="IAS User Group"/>
                                                    <core:Item key="RoleCollection" text="BTP Role Collection"/>
                                                    <core:Item key="Individual" text="Individual User"/>
                                                </items>
                                            </Select>
                                        </VBox>
                                        <VBox class="sapUiSmallMarginEnd">
                                            <Label text="Approver"/>
                                            <ComboBox value="{admin>/pmEdit/newApproverValue}"
                                                      placeholder="Type or select..."
                                                      width="240px"
                                                      items="{admin>/pmEdit/filteredApproverSuggestions}">
                                                <core:ListItem key="{admin>key}" text="{admin>text}"/>
                                            </ComboBox>
                                        </VBox>
                                        <Button text="Add"
                                                icon="sap-icon://add"
                                                press=".onPmEditAddApprover"
                                                class="sapUiSmallMarginBottom"/>
                                    </HBox>
                                </layout:VerticalLayout>
                            </content>
                        </Panel>

                    </layout:VerticalLayout>
                </content>
                <beginButton>
                    <Button text="Save"
                            type="Emphasized"
                            icon="sap-icon://save"
                            press=".onPmEditSave"/>
                </beginButton>
                <endButton>
                    <Button text="Cancel"
                            press=".onPmEditCancel"/>
                </endButton>
            </Dialog>

        </content>
    </Page>

</mvc:View>