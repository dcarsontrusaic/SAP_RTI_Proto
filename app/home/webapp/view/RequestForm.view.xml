<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:layout="sap.ui.layout"
    controllerName="com.trusaic.rti.home.controller.RequestForm"
    displayBlock="true">

    <Page title="New RTI Request"
          showNavButton="true"
          navButtonPress=".onNavBack">
        <content>
            <layout:VerticalLayout class="sapUiMediumMargin" width="auto">

                <form:SimpleForm
                    id="requestForm"
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanL="3" labelSpanM="3"
                    emptySpanL="4" emptySpanM="4"
                    columnsL="1" columnsM="1"
                    class="sapUiSmallMarginBottom">

                    <form:toolbar>
                        <Toolbar>
                            <Title text="Request Details" level="H4"/>
                        </Toolbar>
                    </form:toolbar>

                    <Label text="Language" required="true"/>
                    <Select id="languageSelect"
                            selectedKey="{formModel>/language}"
                            change=".onLanguageChange">
                        <items>
                            <core:Item key="" text="— Select Language —"/>
                            <core:Item key="EN" text="English"/>
                            <core:Item key="DE" text="German (Deutsch)"/>
                            <core:Item key="FR" text="French (Français)"/>
                            <core:Item key="ES" text="Spanish (Español)"/>
                            <core:Item key="IT" text="Italian (Italiano)"/>
                            <core:Item key="PT" text="Portuguese (Português)"/>
                            <core:Item key="NL" text="Dutch (Nederlands)"/>
                            <core:Item key="PL" text="Polish (Polski)"/>
                            <core:Item key="SV" text="Swedish (Svenska)"/>
                            <core:Item key="DA" text="Danish (Dansk)"/>
                            <core:Item key="FI" text="Finnish (Suomi)"/>
                            <core:Item key="NO" text="Norwegian (Norsk)"/>
                        </items>
                    </Select>

                </form:SimpleForm>

                <Bar class="sapUiSmallMarginTop">
                    <contentRight>
                        <Button text="Cancel"
                                type="Default"
                                icon="sap-icon://nav-back"
                                press=".onNavBack"
                                class="sapUiSmallMarginEnd"/>
                        <Button text="Submit Request"
                                type="Emphasized"
                                icon="sap-icon://paper-plane"
                                press=".onSubmit"
                                enabled="{formModel>/submitEnabled}"/>
                    </contentRight>
                </Bar>

            </layout:VerticalLayout>
        </content>
    </Page>

</mvc:View>