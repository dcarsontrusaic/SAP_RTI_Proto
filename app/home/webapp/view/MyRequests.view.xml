<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="com.trusaic.rti.home.controller.MyRequests"
    displayBlock="true">

    <Page title="My Requests"
          showNavButton="true"
          navButtonPress=".onNavBack">
        <headerContent>
            <Button text="New Request"
                    type="Emphasized"
                    icon="sap-icon://add"
                    press=".onNewRequest"/>
        </headerContent>
        <content>
            <Table id="requestsTable"
                   items="{
                       path: '/requests',
                       sorter: { path: 'submittedAt', descending: true }
                   }"
                   growing="true"
                   growingThreshold="20"
                   mode="None">

                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="RTI Requests ({/requestCount})"/>
                        <ToolbarSpacer/>
                        <SearchField placeholder="Search by type..." liveChange=".onSearch" width="250px"/>
                        <Select id="statusFilter"
                                change=".onStatusFilterChange"
                                selectedKey="All">
                            <items>
                                <core:Item xmlns:core="sap.ui.core" key="All" text="All Statuses"/>
                                <core:Item xmlns:core="sap.ui.core" key="Submitted" text="Submitted"/>
                                <core:Item xmlns:core="sap.ui.core" key="UnderReview" text="Under Review"/>
                                <core:Item xmlns:core="sap.ui.core" key="Approved" text="Approved"/>
                                <core:Item xmlns:core="sap.ui.core" key="Denied" text="Denied"/>
                                <core:Item xmlns:core="sap.ui.core" key="Completed" text="Completed"/>
                            </items>
                        </Select>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column width="10em">
                        <Text text="Request ID"/>
                    </Column>
                    <Column>
                        <Text text="Request Type"/>
                    </Column>
                    <Column>
                        <Text text="Comparison Group"/>
                    </Column>
                    <Column width="10em">
                        <Text text="Date Submitted"/>
                    </Column>
                    <Column width="9em">
                        <Text text="Status"/>
                    </Column>
                    <Column width="10em">
                        <Text text="Last Updated"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press="onRequestPress">
                        <cells>
                            <Text text="{ID}"/>
                            <Text text="{requestType}"/>
                            <Text text="{comparisonGroup}"/>
                            <Text text="{parts: ['submittedAt'], formatter: '.formatDate'}"/>
                            <ObjectStatus
                                text="{= ${status} === 'UnderReview' ? 'Under Review' : ${status}}"
                                state="{= ${status} === 'Submitted' ? 'Information' :
                                         ${status} === 'UnderReview' ? 'Warning' :
                                         ${status} === 'Approved' ? 'Success' :
                                         ${status} === 'Completed' ? 'Success' :
                                         ${status} === 'Denied' ? 'Error' : 'None'}"
                                icon="{= ${status} === 'Submitted' ? 'sap-icon://paper-plane' :
                                        ${status} === 'UnderReview' ? 'sap-icon://pending' :
                                        ${status} === 'Approved' ? 'sap-icon://accept' :
                                        ${status} === 'Completed' ? 'sap-icon://complete' :
                                        ${status} === 'Denied' ? 'sap-icon://decline' : ''}"/>
                            <Text text="{parts: ['lastUpdatedAt'], formatter: '.formatDate'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>

</mvc:View>