<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    controllerName="com.trusaic.rti.home.controller.MyRequests"
    displayBlock="true">

    <Page title="My Requests"
          showNavButton="true"
          navButtonPress=".onNavBack">
        <headerContent>
            <Button text="New Request"
                    type="Emphasized"
                    icon="sap-icon://add"
                    press=".onNewRequest"/>
        </headerContent>
        <content>
            <Table id="requestsTable"
                   items="{
                       path: 'view>/requests',
                       sorter: { path: 'submittedAt', descending: true }
                   }"
                   growing="true"
                   growingThreshold="20"
                   mode="None">

                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="RTI Requests ({view>/requestCount})"/>
                        <ToolbarSpacer/>
                        <SearchField placeholder="Search..." liveChange=".onSearch" width="250px"/>
                        <Select id="statusFilter"
                                change=".onStatusFilterChange"
                                selectedKey="All">
                            <items>
                                <core:Item key="All" text="All Statuses"/>
                                <core:Item key="Submitted" text="Submitted"/>
                                <core:Item key="UnderReview" text="Under Review"/>
                                <core:Item key="Approved" text="Approved"/>
                                <core:Item key="Denied" text="Denied"/>
                                <core:Item key="Completed" text="Completed"/>
                            </items>
                        </Select>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column width="10em">
                        <Text text="Request ID"/>
                    </Column>
                    <Column>
                        <Text text="Language"/>
                    </Column>
                    <Column width="10em">
                        <Text text="Date Submitted"/>
                    </Column>
                    <Column width="9em">
                        <Text text="Status"/>
                    </Column>
                    <Column width="10em">
                        <Text text="Last Updated"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press="onRequestPress">
                        <cells>
                            <Text text="{view>ID}"/>
                            <Text text="{view>comparisonGroup}"/>
                            <Text text="{parts: ['view>submittedAt'], formatter: '.formatDate'}"/>
                            <ObjectStatus
                                text="{= ${view>status} === 'UnderReview' ? 'Under Review' : ${view>status}}"
                                state="{= ${view>status} === 'Submitted' ? 'Information' :
                                         ${view>status} === 'UnderReview' ? 'Warning' :
                                         ${view>status} === 'Approved' ? 'Success' :
                                         ${view>status} === 'Completed' ? 'Success' :
                                         ${view>status} === 'Denied' ? 'Error' : 'None'}"
                                icon="{= ${view>status} === 'Submitted' ? 'sap-icon://paper-plane' :
                                        ${view>status} === 'UnderReview' ? 'sap-icon://pending' :
                                        ${view>status} === 'Approved' ? 'sap-icon://accept' :
                                        ${view>status} === 'Completed' ? 'sap-icon://complete' :
                                        ${view>status} === 'Denied' ? 'sap-icon://decline' : ''}"/>
                            <Text text="{parts: ['view>lastUpdatedAt'], formatter: '.formatDate'}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>

</mvc:View>