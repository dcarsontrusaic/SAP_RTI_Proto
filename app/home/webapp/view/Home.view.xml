<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    controllerName="com.trusaic.rti.home.controller.Home"
    displayBlock="true">

    <Page showHeader="false" showNavButton="false">
        <content>
            <layout:VerticalLayout class="sapUiMediumMargin" width="100%">
                <Title text="Welcome" level="H2" class="sapUiMediumMarginBottom"/>
                <Text text="Select an action below to get started." class="sapUiMediumMarginBottom"/>

                <HBox wrap="Wrap" class="sapUiMediumMarginTop" alignItems="Stretch">

                    <!-- Card 1: My Requests -->
                    <f:Card class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="520px">
                        <f:header>
                            <card:Header
                                title="My Requests"
                                subtitle="{/myRequestCount} total requests"
                                iconSrc="sap-icon://list"/>
                        </f:header>
                        <f:content>
                            <VBox class="sapUiSmallMargin" height="298px">
                                <HBox class="sapUiSmallMarginBottom">
                                    <Button text="New Request"
                                            type="Emphasized"
                                            icon="sap-icon://add"
                                            press=".onNewRequest"
                                            class="sapUiSmallMarginEnd"/>
                                    <Button text="View All Requests"
                                            type="Default"
                                            icon="sap-icon://request"
                                            press=".onViewMyRequests"/>
                                </HBox>
                                <Table items="{/recentRequests}"
                                       mode="None"
                                       showSeparators="Inner"
                                       fixedLayout="true"
                                       visible="{= ${/myRequestCount} > 0}">
                                    <headerToolbar>
                                        <Toolbar>
                                            <Title text="Recent" level="H5"/>
                                        </Toolbar>
                                    </headerToolbar>
                                    <columns>
                                        <Column>
                                            <Text text="Language"/>
                                        </Column>
                                        <Column width="8em">
                                            <Text text="Submitted"/>
                                        </Column>
                                        <Column width="9em">
                                            <Text text="Status"/>
                                        </Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem type="Navigation" press=".onRecentRequestPress">
                                            <cells>
                                                <Text text="{comparisonGroup}"/>
                                                <Text text="{parts: ['submittedAt'], formatter: '.formatDate'}"/>
                                                <ObjectStatus
                                                    text="{= ${status} === 'UnderReview' ? 'Under Review' : ${status}}"
                                                    state="{= ${status} === 'Submitted' ? 'Information' :
                                                             ${status} === 'UnderReview' ? 'Warning' :
                                                             ${status} === 'Approved' ? 'Success' :
                                                             ${status} === 'Completed' ? 'Success' :
                                                             ${status} === 'Denied' ? 'Error' : 'None'}"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                                <VBox visible="{= ${/myRequestCount} === 0}"
                                      alignItems="Center"
                                      justifyContent="Center"
                                      class="sapUiSmallMarginTop"
                                      height="100%">
                                    <core:Icon src="sap-icon://document" size="2.5rem" class="sapUiSmallMarginBottom" color="#bbb"/>
                                    <Text text="No requests yet" class="sapUiTinyMarginBottom"/>
                                    <Text text="Submit your first request using the button above."/>
                                </VBox>
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- Card 2: Pending Approvals -->
                    <f:Card class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                            width="320px"
                            visible="{/isApprover}">
                        <f:header>
                            <card:Header
                                title="Pending Approvals"
                                subtitle="{/pendingApprovalCount} awaiting review"
                                iconSrc="sap-icon://approvals"/>
                        </f:header>
                        <f:content>
                            <VBox class="sapUiSmallMargin" height="298px">
                                <Text text="Review and act on RTI requests submitted by employees."/>
                                <Button text="Open Approval Queue"
                                        type="Attention"
                                        press=".onOpenApprovals"
                                        class="sapUiSmallMarginTop"/>
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- Card 3: Admin Settings -->
                    <f:Card class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                            width="320px"
                            visible="{/isAdmin}">
                        <f:header>
                            <card:Header
                                title="Admin Settings"
                                subtitle="Configure Projects and Scopes"
                                iconSrc="sap-icon://settings"/>
                        </f:header>
                        <f:content>
                            <VBox class="sapUiSmallMargin" height="298px">
                                <Text text="Configure project mappings and scope assignments for your organization."
                                      class="sapUiSmallMarginBottom"/>
                                <Button text="Open Settings"
                                        type="Default"
                                        press=".onOpenDashboard"/>
                            </VBox>
                        </f:content>
                    </f:Card>

                </HBox>
            </layout:VerticalLayout>
        </content>
    </Page>

</mvc:View>