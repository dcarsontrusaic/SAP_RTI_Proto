{
  "_version": "1.63.0",
  "sap.app": {
    "id": "com.trusaic.rti.home",
    "type": "application",
    "title": "Pay Transparency — Right to Information",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "employeeService": {
        "uri": "/api/employee/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      },
      "approverService": {
        "uri": "/api/approver/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      },
      "adminService": {
        "uri": "/api/admin/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "rootView": {
      "viewName": "com.trusaic.rti.home.view.App",
      "type": "XML",
      "id": "appView"
    },
    "models": {
      "": {
        "dataSource": "employeeService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "approver": {
        "dataSource": "approverService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "admin": {
        "dataSource": "adminService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.trusaic.rti.home.view",
        "controlId": "appControl",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "name": "home",
          "pattern": "",
          "target": "home"
        },
        {
          "name": "myRequests",
          "pattern": "my-requests",
          "target": "myRequestsFCL"
        },
        {
          "name": "requestDetail",
          "pattern": "my-requests/{requestId}",
          "target": "myRequestsFCL"
        },
        {
          "name": "requestForm",
          "pattern": "new-request",
          "target": "requestForm"
        },
        {
          "name": "approvals",
          "pattern": "approvals",
          "target": "approvalsFCL"
        },
        {
          "name": "approvalDetail",
          "pattern": "approvals/{requestId}",
          "target": "approvalsFCL"
        },
        {
          "name": "adminSettings",
          "pattern": "admin-settings",
          "target": "adminSettings"
        }
      ],
      "targets": {
        "home": {
          "viewName": "Home",
          "viewLevel": 1
        },
        "myRequestsFCL": {
          "viewName": "MyRequestsFCL",
          "viewLevel": 2
        },
        "requestForm": {
          "viewName": "RequestForm",
          "viewLevel": 2
        },
        "approvalsFCL": {
          "viewName": "ApprovalsFCL",
          "viewLevel": 2
        },
        "adminSettings": {
          "viewName": "AdminSettings",
          "viewLevel": 2
        }
      }
    },
    "resources": {
      "css": [
        { "uri": "css/style.css" }
      ]
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {}
      }
    }
  }
}