{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.trusaic.rti.home",
    "type": "application",
    "title": "Pay Transparency — Right to Information",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "employeeService": {
        "uri": "/api/employee/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      },
      "approverService": {
        "uri": "/api/approver/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      },
      "adminService": {
        "uri": "/api/admin/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.trusaic.rti.home.view.App",
      "type": "XML",
      "id": "appView"
    },
    "models": {
      "": {
        "dataSource": "employeeService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "approver": {
        "dataSource": "approverService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "admin": {
        "dataSource": "adminService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.trusaic.rti.home.view",
        "controlId": "appControl",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "name": "home",
          "pattern": "",
          "target": "home"
        },
        {
          "name": "myRequests",
          "pattern": "my-requests",
          "target": "myRequests"
        },
        {
          "name": "requestDetail",
          "pattern": "request/{requestId}",
          "target": "requestDetail"
        }
      ],
      "targets": {
        "home": {
          "viewName": "Home",
          "viewLevel": 1
        },
        "myRequests": {
          "viewName": "MyRequests",
          "viewLevel": 2
        },
        "requestDetail": {
          "viewName": "RequestDetail",
          "viewLevel": 3
        }
      }
    },
    "resources": {
      "css": []
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {}
      }
    }
  }
}